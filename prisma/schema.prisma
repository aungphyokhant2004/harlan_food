// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}


// 1. Admin Authentication (အသစ်ဖြည့်စွက်ချက်)

model AdminUser {
  id               Int       @id @default(autoincrement())
  email            String    @unique
  password         String
  role             AdminRole @default(ADMIN)
  isActive         Boolean   @default(true)
  lastLogin        DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?         // အဆိုပါ ကုဒ် သက်တမ်းကုန်မည့်အချိန်
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  

  @@map("admin_users")
}

enum AdminRole {
  SUPERADMIN
  ADMIN
}

// 2. Menu Management



model MenuCategory {
  id         Int        @id @default(autoincrement())
  name       String
  image      String?
  menuItems  MenuItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model MenuItem {
  id             Int          @id @default(autoincrement())
  name           String
  price          Int
  image          String?
  menuCategoryId Int
  menuCategory   MenuCategory @relation(fields: [menuCategoryId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// 3. Reservation System
model Reservation {
  id                 Int      @id @default(autoincrement())
  bookingDate        String   // mm/dd/yyyy
  bookingTime        String   // hh:mm AM/PM
  guestsCount        Int
  selectedMenu       String   
  
  guestName          String
  phoneNumber        String
  email              String
  otherContactId     String?  
  specialNotes       String?
  
  status             String   @default("pending") // pending, confirmed, cancelled
  agreedToTerms      Boolean @default(false)
  understoodLeadTime Boolean @default(true) 
  paymentScreenshot  String? 
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

}

// 4. Opening Hours
model OpeningHour {
  id        Int      @id @default(autoincrement())
  dayOfWeek String   @unique // Monday, Tuesday, etc.
  openTime  String?  
  closeTime String?  
  isClosed  Boolean  @default(false)

  @@map("opening_hours")
}

// 5. Gallery
model GalleryItem {
  id        Int      @id @default(autoincrement())
  title     String
  type      String   // "image" or "video"
  url       String   
  category  String   // Event, Party, Birthday
  createdAt DateTime @default(now())

  @@map("gallery_items")
}

// 6. Contact Messages
model ContactMessage {
  id        Int      @id @default(autoincrement())
  userName  String   // ပို့တဲ့သူ နာမည်
  userEmail String   // ပို့တဲ့သူ Email
  subject   String?  // ခေါင်းစဉ်
  message   String   // ပေးပို့တဲ့ စာသား
  isRead    Boolean  @default(false) // Admin ဖတ်ပြီး/မဖတ်ပြီး
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

// 🚀 prisma/schema.prisma ၏ အောက်ဆုံးတွင် ထည့်ရန်

model ChatRoom {
  id           Int       @id @default(autoincrement())
  guestName    String    // ဧည့်သည်အမည်
  phoneNumber  String    // ဧည့်သည် ဖုန်းနံပါတ် (ဒါကို အခြေခံပြီး Room ခွဲပါမည်)
  email        String?   // ဧည့်သည် Email
  messages     Message[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("chat_rooms")
  @@index([phoneNumber])
}

model Message {
  id         Int      @id @default(autoincrement())
  roomId     Int
  room       ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderType String   // "GUEST" သို့မဟုတ် "ADMIN"
  text       String   // မက်ဆေ့ခ်ျစာသား
  createdAt  DateTime @default(now())

  @@map("chat_messages")
  @@index([roomId])
}

